# General Configurations
APP_ENV=development
SECRET_KEY=generate_some_secure_key_here

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:secret_password@localhost:5432/arenamind

# Firebase Configuration
FIREBASE_DATABASE_URL=https://arenamind-default-rtdb.firebaseio.com
FIREBASE_CREDENTIALS_JSON_PATH=path/to/firebase-credentials.json

# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
